    "@zitadel/hono-auth": "^1.0.0",
    "dotenv": "^17.4.2",
    "handlebars": "^4.7.9",
    "hono": "^4.12.26",
    "openid-client": "^6.6.2",
    "qs": "^6.15.2"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@tsconfig/node22": "latest",
    "@types/jest": "^30.0.0",
    "@types/node": "^26",
    "@types/qs": "^6.14.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "jest": "^30.2.0",
    "jest-junit": "^17.0.0",
    "knip": "^6.17.1",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "eslint-config-prettier": "^10.1.8",
    "typescript-eslint": "^8.61.1"
  }
