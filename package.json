{
  "name": "example-hono-auth",
  "private": true,
  "scripts": {
    "prepack": "tsc",
    "start": "tsx watch -r dotenv/config src/index.ts",
    "dev": "tsx watch -r dotenv/config src/index.ts",
    "build": "tsc",
    "test": "jest --verbose --config=jest.config.mjs --runInBand",
    "test:watch": "npm run test -- --watch",
    "test:debug": "jest --verbose --config=jest.config.mjs --runInBand --detectOpenHandles",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@auth/core": "^0.41.2",
    "@hono/auth-js": "^1.1.0",
    "@hono/node-server": "^2.0.2",
    "dotenv": "^17.4.2",
    "handlebars": "^4.7.9",
    "hono": "^4.12.18",
    "openid-client": "^6.8.4",
    "qs": "^6.15.1"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@tsconfig/node22": "latest",
    "@types/jest": "^30.0.0",
    "@types/node": "^25",
    "@types/qs": "^6.15.1",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.34.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "knip": "^6.13.1",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
